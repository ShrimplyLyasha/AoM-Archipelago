        trProtounitAddTrain("TempleOvergrown", 1, "Promethean",     0, 1);
        trProtounitAddTrain("TempleOvergrown", 1, "Caladria",       0, 1);
        trProtounitAddTrain("TempleOvergrown", 1, "Satyr",          0, 2);
        trProtounitAddTrain("TempleOvergrown", 1, "Behemoth",       0, 2);
        trProtounitAddTrain("TempleOvergrown", 1, "StymphalianBird",0, 2);
        trProtounitAddTrain("TempleOvergrown", 1, "Centimanus",     0, 3);
        trProtounitAddTrain("TempleOvergrown", 1, "Lampades",       0, 3);
        trProtounitAddTrain("TempleOvergrown", 1, "Argus",          0, 3);
        // ---- Chinese units ----
        trProtounitAddTrain("TempleOvergrown", 1, "Pioneer",        0, 0);
        trProtounitAddTrain("TempleOvergrown", 1, "QiLin",          0, 1);
        trProtounitAddTrain("TempleOvergrown", 1, "YaZi",           0, 1);
        trProtounitAddTrain("TempleOvergrown", 1, "QiongQi",        0, 1);
        trProtounitAddTrain("TempleOvergrown", 1, "TaoTie",         0, 2);
        trProtounitAddTrain("TempleOvergrown", 1, "BaiHu",          0, 2);
        trProtounitAddTrain("TempleOvergrown", 1, "TaoWu",          0, 2);
        trProtounitAddTrain("TempleOvergrown", 1, "QingLong",       0, 3);
        trProtounitAddTrain("TempleOvergrown", 1, "HunDun",         0, 3);
        trProtounitAddTrain("TempleOvergrown", 1, "ZhuQue",         0, 3);
        // ---- Japanese units ----
        trProtounitAddTrain("TempleOvergrown", 1, "Kitsune",        0, 0);
        trProtounitAddTrain("TempleOvergrown", 1, "Jorogumo",       0, 1);
        trProtounitAddTrain("TempleOvergrown", 1, "Kamaitachi",     0, 1);
        trProtounitAddTrain("TempleOvergrown", 1, "Wanyudo",        0, 1);
        trProtounitAddTrain("TempleOvergrown", 1, "Tengu",          0, 2);
        trProtounitAddTrain("TempleOvergrown", 1, "Oni",            0, 2);
        trProtounitAddTrain("TempleOvergrown", 1, "Raiju",          0, 2);
        trProtounitAddTrain("TempleOvergrown", 1, "Asura",          0, 3);
        trProtounitAddTrain("TempleOvergrown", 1, "Shinigami",      0, 3);
        trProtounitAddTrain("TempleOvergrown", 1, "Onmoraki",       0, 3);

        // ---- Greek techs ----
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("WingedMessenger"),   1, 0);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("LabyrinthOfMinos"),  1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("SylvanLore"),        1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("PredatoryInstinct"), 1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("WillOfKronos"),      1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("RoarOfOrthus"),      1, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("ChthonicRites"),     1, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("HallowedWoodlands"), 1, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("FaceOfTheGorgon"),   1, 3);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("FlamesOfTyphon"),    1, 3);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("HandOfTalos"),       1, 3);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("ShoulderOfTalos"),   1, 3);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("EnchantedHymn"),     1, 3);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("NepheleanHarpy"),    1, 4);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("OlympianParentage"), 2, 0);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("PansPioneers"),      2, 0);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("TempleOfHealing"),   2, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("GoldenApples"),      2, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Dionysia"),          2, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Oracle"),            2, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("MonstrousRage"),     2, 3);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("PiousSacrifice"),    2, 3);
        // ---- Egyptian techs ----
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("HandsOfThePharaoh"), 1, 0);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("FeetOfTheJackal"),   1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Criosphinx"),        1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Hieracosphinx"),     1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("FuneralRites"),      1, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Crocodilopolis"),    1, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("AtefCrown"),         1, 3);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("NewKingdom"),        1, 4);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Clairvoyance"),      2, 0);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Shaduf"),            2, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Necropolis"),        2, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("SpiritOfMaat"),      2, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("CrimsonLinen"),      2, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Nebty"),             2, 3);
