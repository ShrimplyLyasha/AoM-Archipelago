// APForbidNonAssignedGreekMajorGodHeroes -- each Greek major god enables its
// own heroes through major-god age techs (ClassicalAge<God> -> classical hero,
// HeroicAge<God> -> heroic hero, MythicAge<God> -> mythic hero) plus an archaic
// hero Enable tech (Jason/Theseus/Ajax/Orpheus).  APForceDisableAllGreekAgeTechs
// only clears the minor-god techs, so when random_major_gods swaps the player
// onto a different Greek god the vanilla scenario's major-god techs stay active
// and keep the old god's heroes trainable (e.g. a Demeter player on a vanilla
// Hades map could still train Achilles + Perseus).  Force-disable every Greek
// major god's hero techs EXCEPT the assigned one.  When the assigned god is not
// Greek (majorGod matches none), all four are disabled.  Hero<->god mapping is
// from techtree.xml.  Caller: APApplyGreekMinorGods.
// Greek major-god hero roster (from techtree.xml):
//   Zeus     : Jason (A), Heracles (C), Odysseus (H), Bellerophon (M)
//   Poseidon : Theseus (A), Atalanta (C), Hippolyta (H), Polyphemus (M)
//   Hades    : Ajax (A), Achilles (C), Chiron (H), Perseus (M)
//   Demeter  : Orpheus (A), Iolaus (C), Icarus (H), Midas (M)
// For each non-assigned god, disable its major-god age techs + archaic enable
// tech AND explicitly forbid its hero protos (the age-tech disable alone does
// not reliably revert an already-granted Enable on a vanilla scenario).  The
// assigned god's heroes are left alone here.  Odysseus / Ajax / Chiron are
// never enabled for anyone (handled in the APEnforceAgeLocks watcher) because
// they appear as named SPC campaign characters.  Caller: APApplyAgeUnlocks.
void APForbidNonAssignedGreekMajorGodHeroes(int majorGod = 0)
{
    if (majorGod != cAPMajorZeus)
    {
        trTechSetStatus(1, kbTechGetID("ArchaicAgeZeus"),   0);
        trTechSetStatus(1, kbTechGetID("ClassicalAgeZeus"), 0);
        trTechSetStatus(1, kbTechGetID("HeroicAgeZeus"),    0);
        trTechSetStatus(1, kbTechGetID("MythicAgeZeus"),    0);
        trTechSetStatus(1, kbTechGetID("JasonEnable"),      0);
        trForbidProtounit(1, "Jason");
        trForbidProtounit(1, "Heracles");
        trForbidProtounit(1, "Bellerophon");
    }
    if (majorGod != cAPMajorPoseidon)
    {
        trTechSetStatus(1, kbTechGetID("ArchaicAgePoseidon"),   0);
        trTechSetStatus(1, kbTechGetID("ClassicalAgePoseidon"), 0);
        trTechSetStatus(1, kbTechGetID("HeroicAgePoseidon"),    0);
        trTechSetStatus(1, kbTechGetID("MythicAgePoseidon"),    0);
        trTechSetStatus(1, kbTechGetID("TheseusEnable"),        0);
        trForbidProtounit(1, "Theseus");
        trForbidProtounit(1, "Atalanta");
        trForbidProtounit(1, "Hippolyta");
        trForbidProtounit(1, "Polyphemus");
    }
    if (majorGod != cAPMajorHades)
    {
        trTechSetStatus(1, kbTechGetID("ArchaicAgeHades"),   0);
        trTechSetStatus(1, kbTechGetID("ClassicalAgeHades"), 0);
        trTechSetStatus(1, kbTechGetID("HeroicAgeHades"),    0);
        trTechSetStatus(1, kbTechGetID("MythicAgeHades"),    0);
        trTechSetStatus(1, kbTechGetID("AjaxEnable"),        0);
        trForbidProtounit(1, "Achilles");
        trForbidProtounit(1, "Perseus");
    }
    if (majorGod != cAPMajorDemeter)
    {
        trTechSetStatus(1, kbTechGetID("ArchaicAgeDemeter"),   0);
        trTechSetStatus(1, kbTechGetID("ClassicalAgeDemeter"), 0);
        trTechSetStatus(1, kbTechGetID("HeroicAgeDemeter"),    0);
        trTechSetStatus(1, kbTechGetID("MythicAgeDemeter"),    0);
        trTechSetStatus(1, kbTechGetID("OrpheusEnable"),       0);
        trForbidProtounit(1, "Orpheus");
        trForbidProtounit(1, "Iolaus");
        trForbidProtounit(1, "Icarus");
        trForbidProtounit(1, "Midas");
    }
}

// APApply<Civ>MinorGods â€" set up the player's age techs for the current
// civilization.  Force-disables every Greek age tech, then re-enables the
// floor base age techs (status 2 = researched) and makes above-floor base
// age techs researchable (status 1) up to ageCount.  Minor god selection
// is layered on top by the generated APApplyMinorGodSelection in aom_state.xs.
//
// Args:
//   majorGod      â€" current major god (e.g. cAPMajorZeus); informational.
//   ageCount      â€" number of GREEK_AGE_UNLOCK items the player has;
//                   determines how high above the floor base age techs become
//                   researchable.
//   startingFloor â€" the scenario's starting age tier (1=Classical, 2=Heroic,
//                   3=Mythic).  Tiers <= floor get status 2 outright.
//
// Caller: APApplyAgeUnlocks (via the dispatcher tree there).
void APApplyGreekMinorGods(int majorGod = 0, int ageCount = 0, int startingFloor = 0)
{
    // Force-disable all Greek age techs, then re-enable the base age techs only.
    // Minor-god tech selection (exactly one per tier) is handled by the generated
    // APApplyMinorGodSelection(), called after this function in APApplyAgeUnlocks().
    APForceDisableAllGreekAgeTechs();

    // Re-activate floor base age techs (force-disable cleared them).
    if (startingFloor >= 1) { trTechSetStatus(1, cTechClassicalAgeGreek, 2); }
    if (startingFloor >= 2) { trTechSetStatus(1, cTechHeroicAgeGreek,    2); }
    if (startingFloor >= 3) { trTechSetStatus(1, cTechMythicAgeGreek,    2); }

    // Set base age techs researchable for tiers above the starting floor.
    if (ageCount >= 1 && startingFloor < 1) { trTechSetStatus(1, cTechClassicalAgeGreek, 1); }
    if (ageCount >= 2 && startingFloor < 2) { trTechSetStatus(1, cTechHeroicAgeGreek,    1); }
    if (ageCount >= 3 && startingFloor < 3) { trTechSetStatus(1, cTechMythicAgeGreek,    1); }
}

void APApplyEgyptianMinorGods(int majorGod = 0, int ageCount = 0, int startingFloor = 0)
{
    // Base age techs only â€" minor-god selection handled by APApplyMinorGodSelection().
    APForceDisableAllEgyptianAgeTechs();

    if (startingFloor >= 1) { trTechSetStatus(1, cTechClassicalAgeEgyptian, 2); }
    if (startingFloor >= 2) { trTechSetStatus(1, cTechHeroicAgeEgyptian,    2); }
    if (startingFloor >= 3) { trTechSetStatus(1, cTechMythicAgeEgyptian,    2); }

    if (ageCount >= 1 && startingFloor < 1) { trTechSetStatus(1, cTechClassicalAgeEgyptian, 1); }
    if (ageCount >= 2 && startingFloor < 2) { trTechSetStatus(1, cTechHeroicAgeEgyptian,    1); }
    if (ageCount >= 3 && startingFloor < 3) { trTechSetStatus(1, cTechMythicAgeEgyptian,    1); }
}

