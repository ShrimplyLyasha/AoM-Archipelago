        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("PropheticSight"),    2, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("SonsOfTheSun"),      2, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("HeroicRenewal"),     2, 3);
        // ---- Chinese techs ----
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("DivineLight"),       1, 0);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("EastWind"),          1, 0);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("SkyFire"),           1, 0);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("QiLinsBlessing"),    1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("SonOfLoong"),        1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("RageOfSlaughter"),   1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("SinisterDefiance"),  1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("FrenziedDash"),      1, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("BottomlessStomach"), 1, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("RisingTide"),        1, 3);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("PowerOfChaos"),      1, 3);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("SongOfMidsummer"),   1, 3);
