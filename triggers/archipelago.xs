        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("HallOfThanes"),      1, 0);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Safeguard"),         1, 0);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("AvengingSpirit"),    1, 0);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("EyesInTheForest"),   2, 0);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Gjallarhorn"),       1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("CaveTroll"),         1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Disablot"),          1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Valgaldr"),          1, 1);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("GraniteMaw"),        1, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Rime"),              1, 3);
