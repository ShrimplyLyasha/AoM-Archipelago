        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Rampage"),           2, 2);
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("GraniteBlood"),      2, 3);
        // ---- Atlantean techs ----
        trProtounitAddTech("TempleOvergrown", 1, kbTechGetID("Channels"),          1, 0);
